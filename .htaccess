# ============================================
# خيارات الأمان — موقع نور
# ============================================

# منع الوصول المباشر للملفات الحساسة
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

<FilesMatch "(^#|~$|\.bak$|\.swp$|\.old$|\.orig$|\.sql$|\.log$|\.env$)">
  Require all denied
</FilesMatch>

# منع تصفح الدليل
Options -Indexes

# حماية .htaccess نفسه
<Files ".htaccess">
  Require all denied
</Files>

# ============================================
# رؤوس الأمان (Security Headers)
# ============================================

<IfModule mod_headers.c>
  # Content Security Policy — يمنع XSS وحقن الشيفرات
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com data:; connect-src 'self' https://api.aladhan.com https://api.alquran.cloud https://cdn.islamic.network https://download.islamic.network https://api.hadith.gading.dev; img-src 'self' data:; frame-ancestors 'none'; form-action 'self'; base-uri 'self'"

  # منع Clickjacking
  Header always set X-Frame-Options "DENY"

  # منع MIME sniffing
  Header always set X-Content-Type-Options "nosniff"

  # تفعيل حماية XSS في المتصفحات القديمة
  Header always set X-XSS-Protection "1; mode=block"

  # سياسة الإحالة — الخصوصية
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # سياسة الصلاحيات — تقييد الوصول للكاميرا والميكروفون
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(self), interest-cohort=()"

  # --- التخزين المؤقت والذاكرة المخبأة ---
  # الموارد الثابتة — تخزين طويل الأمد
  <FilesMatch "\.(ico|pdf|flv|woff2?|eot|ttf|svg)$">
    Header set Cache-Control "max-age=31536000, public, immutable"
  </FilesMatch>

  <FilesMatch "\.(jpg|jpeg|png|gif|webp)$">
    Header set Cache-Control "max-age=86400, public, immutable"
  </FilesMatch>

  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "max-age=604800, public, immutable"
  </FilesMatch>

  # صفحات HTML — عدم التخزين المؤقت للمحتوى الحساس
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # --- HSTS — إجبار HTTPS (منع هجمات SSL Stripping) ---
  # لاحظ: يجب تفعيل HTTPS أولاً على السيرفر قبل استخدام هذا السطر
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # --- ضغط التصفح (Preload / Prefetch) ---
  # يمكن إضافة روابط مسبقة للموارد المهمة:
  # Header set Link "<https://cdnjs.cloudflare.com>; rel=preconnect"
  # Header set Link "<https://fonts.googleapis.com>; rel=preconnect"
</IfModule>

# ============================================
# ضغط Gzip/Brotli
# ============================================

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

# ============================================
# إعادة التوجيه إلى HTTPS
# ============================================

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]
</IfModule>

# ============================================
# إعادة التوجيه إلى index.html (للمسارات غير الموجودة)
# ============================================

